---
import { SITE_TITLE } from "../consts";
---

<div class="sticky top-0 z-50 border-b border-gray-800 bg-[#0b0f17]/80 backdrop-blur-md">
  <div class="flex justify-between items-center px-8 py-5 max-w-6xl mx-auto">

    <a href="/" class="font-bold text-xl">
      {SITE_TITLE}
    </a>

    <div class="flex gap-6 text-sm text-gray-400">
      <a class="hover:text-white transition" href="/">Home</a>
      <a class="hover:text-white transition" href="/blog">Blog</a>
      <a class="hover:text-white transition" href="/about">About</a>
      <a class="hover:text-white transition" href="https://github.com/packetalchemy">GitHub</a>
    </div>

  </div>
</div>