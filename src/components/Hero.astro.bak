<div class="max-w-4xl mx-auto px-8 py-24">
  
  <h1 class="text-5xl font-bold leading-tight">
    Engineering Telecom Systems
    <span class="text-blue-500">at Scale</span>
  </h1>

  <p class="mt-6 text-gray-400 text-lg">
    Deep dive into 5G Core, EPC architecture, signaling protocols,
    DNS routing, and real-world telecom troubleshooting.
  </p>

  <div class="flex gap-4 mt-10">
    <a class="px-5 py-3 bg-blue-600 rounded-lg" href="/blog">
      Explore Knowledge
    </a>
    <a class="px-5 py-3 border border-gray-700 rounded-lg" href="/projects">
      View Labs
    </a>
  </div>

  <div class="flex flex-wrap gap-3 mt-10">
    <span class="px-3 py-1 border border-gray-700 rounded-full text-sm">5G Core</span>
    <span class="px-3 py-1 border border-gray-700 rounded-full text-sm">EPC</span>
    <span class="px-3 py-1 border border-gray-700 rounded-full text-sm">GTP</span>
    <span class="px-3 py-1 border border-gray-700 rounded-full text-sm">Diameter</span>
    <span class="px-3 py-1 border border-gray-700 rounded-full text-sm">Wireshark</span>
    <span class="px-3 py-1 border border-gray-700 rounded-full text-sm">Cloud Native</span>
  </div>

</div>