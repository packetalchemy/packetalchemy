---
interface Props {
  t: any;
  lang: string;
}

const { t, lang } = Astro.props;
const isFa = lang === 'fa';
---

<footer class:list={["border-t border-white/5 mt-24", isFa && "rtl"]}>
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-14">
    <div class="grid md:grid-cols-4 gap-10">
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img src="/favicon.svg" alt="PA" class="w-8 h-8 rounded-lg" />
          <span class="text-lg font-bold">PacketAlchemy</span>
        </div>
        <p class="text-gray-500 text-sm leading-relaxed max-w-sm">
          {isFa
            ? 'مهندسی شبکه‌های مخابراتی — به اشتراک‌گذاری دانش درباره 5G Core، PS Core، تحلیل پکت و تجهیزات هوآوی.'
            : 'Engineering telecom networks — sharing knowledge about 5G Core, PS Core, packet analysis, and Huawei equipment.'}
        </p>
      </div>
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">{t.footer.links}</h4>
        <ul class="space-y-2.5 text-sm text-gray-500">
          <li><a href={isFa ? '/fa/blog' : '/blog'} class="hover:text-white transition-colors">{t.nav.blog}</a></li>
          <li><a href={isFa ? '/fa/projects' : '/projects'} class="hover:text-white transition-colors">{t.nav.projects}</a></li>
          <li><a href={isFa ? '/fa/reference' : '/reference'} class="hover:text-white transition-colors">{t.nav.reference}</a></li>
          <li><a href={isFa ? '/fa/glossary' : '/glossary'} class="hover:text-white transition-colors">{t.nav.glossary}</a></li>
          <li><a href={isFa ? '/fa/about' : '/about'} class="hover:text-white transition-colors">{t.nav.about}</a></li>
          <li><a href={isFa ? '/fa/contact' : '/contact'} class="hover:text-white transition-colors">{t.nav.contact}</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">{t.footer.topics}</h4>
        <ul class="space-y-2.5 text-sm text-gray-500">
          <li>PS Core</li>
          <li>5G Core</li>
          <li>EPC / LTE</li>
          <li>Wireshark</li>
        </ul>
      </div>
    </div>
    <div class="border-t border-white/5 mt-10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-gray-600 text-xs">{t.footer.copyright}</div>
      <div class="flex gap-4">
        <a href="https://github.com/packetalchemy" target="_blank" class="text-gray-600 hover:text-white transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
