---
interface Props {
  lang: string;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

// lang = CURRENT page language
// We want to switch to the OTHER language
let targetPath: string;
if (lang === 'fa') {
  // Currently Persian → switch to English (remove /fa prefix)
  targetPath = currentPath.replace(/^\/fa/, '') || '/';
} else {
  // Currently English → switch to Persian (add /fa prefix)
  targetPath = '/fa' + (currentPath === '/' ? '' : currentPath);
}
---

<a
  href={targetPath}
  class="px-3 py-1.5 rounded-lg text-xs font-semibold border border-white/10 hover:border-blue-500/40 hover:bg-blue-500/10 transition-all text-gray-400 hover:text-white"
  title={lang === 'en' ? 'فارسی' : 'English'}
>
  {lang === 'en' ? 'فارسی' : 'EN'}
</a>
