---
import { SITE_TITLE } from "../consts";
---

<div class="sticky top-0 z-50 border-b border-white/5 bg-[#0b0f17]/80 backdrop-blur-xl">
  <div class="flex justify-between items-center px-6 md:px-10 py-4 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-blue-500 to-cyan-400 flex items-center justify-center text-white font-black text-sm tracking-tighter">
        PA
      </div>
      <span class="font-bold text-lg text-white group-hover:text-blue-400 transition-colors">
        {SITE_TITLE}
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-1 text-sm">
      <a class="px-4 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/">Home</a>
      <a class="px-4 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/blog">Blog</a>
      <a class="px-4 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/projects">Projects</a>
      <a class="px-4 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/reference">Reference</a>
      <a class="px-4 py-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/about">About</a>
      <a
        class="ml-2 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-gray-300 hover:text-white hover:border-blue-500/50 hover:bg-blue-500/10 transition-all flex items-center gap-2"
        href="https://github.com/packetalchemy"
        target="_blank"
        rel="noopener"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-400 hover:text-white"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 px-6 pb-4">
    <nav class="flex flex-col gap-1 text-sm pt-2">
      <a class="px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/">Home</a>
      <a class="px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/blog">Blog</a>
      <a class="px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/projects">Projects</a>
      <a class="px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/reference">Reference</a>
      <a class="px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="/about">About</a>
      <a class="px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-all" href="https://github.com/packetalchemy" target="_blank">GitHub</a>
    </nav>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
