---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PacketAlchemy</title>
  </head>

  <body class="bg-zinc-950 text-white">
    <main class="min-h-screen flex flex-col justify-center items-center px-6">

      <h1 class="text-6xl font-bold">
        PacketAlchemy
      </h1>

      <p class="mt-6 text-xl text-zinc-400 text-center max-w-2xl">
        Engineering Networks.
        Building Knowledge.
      </p>

      <p class="mt-4 text-zinc-500 text-center max-w-3xl">
        Telecom Core Engineering • 5G • EPC • Cloudflare • Open Source
      </p>

      <div class="mt-10 flex gap-4">

        <a
          href="https://github.com/packetalchemy"
          class="rounded-xl bg-blue-600 px-6 py-3 hover:bg-blue-500 transition"
        >
          GitHub
        </a>

        <a
          href="#projects"
          class="rounded-xl border border-zinc-700 px-6 py-3 hover:border-white transition"
        >
          Projects
        </a>

      </div>

    </main>
  </body>

</html>