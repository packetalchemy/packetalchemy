---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>PacketAlchemy</title>

    <style>
      body {
        margin: 0;
        font-family: system-ui;
        background: #0b0f17;
        color: #e5e7eb;
      }

      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 100px 24px;
      }

      .title {
        font-size: 52px;
        font-weight: 700;
      }

      .subtitle {
        margin-top: 16px;
        font-size: 18px;
        color: #9ca3af;
        line-height: 1.6;
      }

      .tags {
        margin-top: 30px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .tag {
        padding: 6px 12px;
        border: 1px solid #374151;
        border-radius: 999px;
        font-size: 13px;
        color: #cbd5e1;
      }

      .buttons {
        margin-top: 40px;
        display: flex;
        gap: 12px;
      }

      .btn {
        padding: 10px 18px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 500;
      }

      .primary {
        background: #3b82f6;
        color: white;
      }

      .secondary {
        border: 1px solid #374151;
        color: #e5e7eb;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="title">PacketAlchemy</div>

      <div class="subtitle">
        Engineering telecom systems at scale — from EPC to 5G Core, DNS routing,
        signaling, and real-world network troubleshooting.
      </div>

      <div class="tags">
        <div class="tag">5G Core</div>
        <div class="tag">EPC</div>
        <div class="tag">GTP</div>
        <div class="tag">Diameter</div>
        <div class="tag">Wireshark</div>
        <div class="tag">Cloud Networking</div>
      </div>

      <div class="buttons">
        <a class="btn primary" href="/blog">Explore Knowledge</a>
        <a class="btn secondary" href="https://github.com/packetalchemy">GitHub</a>
      </div>
    </div>
  </body>
</html>