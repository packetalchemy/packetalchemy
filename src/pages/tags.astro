---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Build tag map
const tagMap = new Map<string, typeof posts>();
posts.forEach(post => {
  const tags = (post.data as any).tags || [];
  tags.forEach((tag: string) => {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(post);
  });
});

const sortedTags = [...tagMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<MainLayout title="Tags | PacketAlchemy">

<section class="relative overflow-hidden">
  <div class="absolute -right-64 -top-64 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>
  <div class="relative max-w-5xl mx-auto px-6 md:px-10 pt-28 pb-12">
    <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-xs text-blue-300 mb-6">
      <span class="h-1.5 w-1.5 rounded-full bg-blue-400"></span>
      Content Index
    </div>
    <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight">
      Topics &
      <span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent"> Tags</span>
    </h1>
    <p class="text-gray-400 mt-4 text-lg">Browse all articles by topic</p>
  </div>
</section>

<section class="max-w-5xl mx-auto px-6 md:px-10 pb-20">

  <!-- Tag Cloud -->
  <div class="flex flex-wrap gap-3 mb-14">
    {sortedTags.map(([tag, tagPosts]) => (
      <a
        href={`#${tag.toLowerCase().replace(/[^a-z0-9]/g, '-')}`}
        class="px-4 py-2 rounded-xl bg-white/[0.03] border border-white/5 hover:border-blue-500/40 hover:bg-blue-500/10 transition-all text-sm text-gray-300 hover:text-white"
      >
        {tag}
        <span class="text-gray-600 ml-1">({tagPosts.length})</span>
      </a>
    ))}
  </div>

  <!-- Posts by Tag -->
  {sortedTags.map(([tag, tagPosts]) => (
    <div id={tag.toLowerCase().replace(/[^a-z0-9]/g, '-')} class="mb-14 scroll-mt-24">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
        <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
        {tag}
        <span class="text-sm text-gray-500 font-normal">({tagPosts.length} articles)</span>
      </h2>
      <div class="space-y-4">
        {tagPosts.map(post => (
          <a
            href={`/blog/${post.id}/`}
            class="block rounded-xl border border-white/5 bg-white/[0.02] p-6 hover:border-blue-500/30 hover:-translate-y-0.5 transition-all duration-300"
          >
            <div class="text-xs text-gray-500 font-mono">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
            <h3 class="text-lg font-bold mt-1 hover:text-blue-400 transition-colors">{post.data.title}</h3>
            <p class="text-gray-400 text-sm mt-2 leading-relaxed">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  ))}

</section>
</MainLayout>
