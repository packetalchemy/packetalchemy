---
import I18nLayout from '../../layouts/I18nLayout.astro';
import { getLocale } from '../../i18n/index';
const lang = 'fa' as const;
const t = getLocale(lang);
---
<I18nLayout title="تماس | PacketAlchemy" lang={lang}>
<section class="relative overflow-hidden">
  <div class="absolute -right-64 -top-64 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>
  <div class="relative max-w-5xl mx-auto px-6 md:px-10 pt-28 pb-12 rtl">
    <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-xs text-blue-300 mb-6">
      <span class="h-1.5 w-1.5 rounded-full bg-blue-400"></span>{t.contact.badge}
    </div>
    <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight">{t.contact.title}</h1>
    <p class="text-gray-400 mt-4 text-lg max-w-2xl">{t.contact.subtitle}</p>
  </div>
</section>
<section class="max-w-4xl mx-auto px-6 md:px-10 pb-20 rtl">
  <div class="grid md:grid-cols-2 gap-6">
    <a href="https://github.com/packetalchemy" target="_blank" class="rounded-2xl border border-white/5 bg-white/[0.02] p-8 hover:border-blue-500/30 transition-all group">
      <div class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center text-gray-400 group-hover:text-white transition">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </div>
      <h3 class="text-lg font-bold mt-4">{t.contact.github}</h3>
      <p class="text-gray-400 text-sm mt-2">{t.contact.githubDesc}</p>
      <span class="text-blue-400 text-sm mt-4 inline-block">packetalchemy →</span>
    </a>
    <a href="/rss.xml" target="_blank" class="rounded-2xl border border-white/5 bg-white/[0.02] p-8 hover:border-blue-500/30 transition-all group">
      <div class="w-12 h-12 rounded-xl bg-orange-500/10 flex items-center justify-center text-orange-400">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.37 20 6.18 20c-1.19 0-2.18-.99-2.18-2.18 0-1.2.99-2.18 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
      </div>
      <h3 class="text-lg font-bold mt-4">{t.contact.rss}</h3>
      <p class="text-gray-400 text-sm mt-2">{t.contact.rssDesc}</p>
      <span class="text-orange-400 text-sm mt-4 inline-block">RSS Feed →</span>
    </a>
  </div>
</section>
</I18nLayout>
