---
import I18nLayout from '../../layouts/I18nLayout.astro';
import { getLocale } from '../../i18n/index';
const lang = 'fa' as const;
const t = getLocale(lang);
---
<I18nLayout title="پروژه‌ها | PacketAlchemy" lang={lang}>
<section class="relative overflow-hidden">
  <div class="absolute -left-64 -top-64 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>
  <div class="relative max-w-5xl mx-auto px-6 md:px-10 pt-28 pb-12 rtl">
    <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-xs text-blue-300 mb-6">
      <span class="h-1.5 w-1.5 rounded-full bg-blue-400"></span>{t.projects.badge}
    </div>
    <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight">{t.projects.title}<span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent"> {t.projects.titleHighlight}</span></h1>
    <p class="text-gray-400 mt-4 text-lg max-w-2xl">{t.projects.subtitle}</p>
  </div>
</section>
<section class="max-w-5xl mx-auto px-6 md:px-10 pb-20 rtl">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-blue-500/30 transition-all"><div class="flex items-center gap-3 mb-3"><div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400">📡</div><h2 class="text-lg font-bold">شبیه‌ساز جریان 5G Core</h2></div><p class="text-gray-400 text-sm leading-relaxed">شبیه‌سازی جریان‌های سیگنالینگ AMF → SMF → UPF با تحلیل GTP.</p><div class="flex gap-2 mt-5"><span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">5GC</span><span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">SBA</span></div></div>
    <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-blue-500/30 transition-all"><div class="flex items-center gap-3 mb-3"><div class="w-10 h-10 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400">🔍</div><h2 class="text-lg font-bold">آزمایشگاه عیب‌یابی EPC</h2></div><p class="text-gray-400 text-sm leading-relaxed">تحلیل پکت MME, SGW, PGW با Wireshark.</p><div class="flex gap-2 mt-5"><span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">EPC</span><span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">GTP</span></div></div>
    <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-blue-500/30 transition-all"><div class="flex items-center gap-3 mb-3"><div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400">🌐</div><h2 class="text-lg font-bold">آزمایشگاه PS Core هوآوی</h2></div><p class="text-gray-400 text-sm leading-relaxed">تمرین با تجهیزات هوآوی: USN, UGW, CG, UPCC.</p><div class="flex gap-2 mt-5"><span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">Huawei</span><span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">PS Core</span></div></div>
    <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-blue-500/30 transition-all"><div class="flex items-center gap-3 mb-3"><div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400">⚡</div><h2 class="text-lg font-bold">تحلیلگر سیگنالینگ Diameter</h2></div><p class="text-gray-400 text-sm leading-relaxed">تحلیل جریان‌های CCR/CCA در سیستم‌های شارژینگ LTE.</p><div class="flex gap-2 mt-5"><span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">Diameter</span><span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">OCS</span></div></div>
  </div>
</section>
</I18nLayout>
