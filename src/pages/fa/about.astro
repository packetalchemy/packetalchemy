---
import I18nLayout from '../../layouts/I18nLayout.astro';
import { getLocale } from '../../i18n/index';

const lang = 'fa' as const;
const t = getLocale(lang);
---

<I18nLayout title="درباره من | PacketAlchemy" lang={lang}>

<section class="relative overflow-hidden">
  <div class="absolute -right-64 -top-64 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>
  <div class="relative max-w-5xl mx-auto px-6 md:px-10 pt-28 pb-16 rtl">
    <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-xs text-blue-300 mb-6">
      <span class="h-1.5 w-1.5 rounded-full bg-blue-400"></span>
      {t.about.badge}
    </div>
    <h1 class="text-4xl md:text-6xl font-black leading-tight tracking-tight">
      {t.about.title}
      <br />
      <span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">
        {t.about.titleHighlight}
      </span>
    </h1>
  </div>
</section>

<section class="max-w-4xl mx-auto px-6 md:px-10 pb-20 rtl">
  <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-8 md:p-10">
    <p class="text-lg md:text-xl leading-relaxed text-gray-300">
      {t.about.bio}
    </p>
  </div>

  <div class="mt-16">
    <h2 class="text-2xl font-bold mb-8">{t.about.careerPath}</h2>
    <div class="space-y-0">
      <div class="relative pl-8 border-l border-white/10 pb-12">
        <div class="absolute left-0 top-0 w-2 h-2 -ml-[4.5px] rounded-full bg-blue-500 ring-4 ring-[#0b0f17]"></div>
        <div class="text-xs text-blue-400 font-semibold uppercase tracking-wider">۱۱+ سال</div>
        <h3 class="text-xl font-bold mt-2">مهندس PS Core</h3>
        <p class="text-gray-400 mt-2 leading-relaxed">تخصص در سیستم‌های پکت‌سوئیچ هسته‌ای با تمرکز بر تجهیزات هوآوی: USN, UGW, CG, UPCC, vUGW, vUSN, VCG.</p>
      </div>
      <div class="relative pl-8 border-l border-white/10 pb-12">
        <div class="absolute left-0 top-0 w-2 h-2 -ml-[4.5px] rounded-full bg-blue-500/60 ring-4 ring-[#0b0f17]"></div>
        <div class="text-xs text-gray-500 font-semibold uppercase tracking-wider">۲۱+ سال</div>
        <h3 class="text-xl font-bold mt-2">مهندسی مخابرات</h3>
        <p class="text-gray-400 mt-2 leading-relaxed">شروع کار در صنعت تلکام با مدرک لیسانس الکترونیک. تجربه گسترده در شبکه‌های مخابراتی و زیرساخت‌های هسته‌ای.</p>
      </div>
      <div class="relative pl-8 border-l border-white/10">
        <div class="absolute left-0 top-0 w-2 h-2 -ml-[4.5px] rounded-full bg-cyan-500/60 ring-4 ring-[#0b0f17]"></div>
        <div class="text-xs text-cyan-400 font-semibold uppercase tracking-wider">فعال</div>
        <h3 class="text-xl font-bold mt-2">یادگیری و توسعه</h3>
        <p class="text-gray-400 mt-2 leading-relaxed">علاقه‌مند به تحلیل پکت، هوش مصنوعی، برنامه‌نویسی و کار با GitHub. پیگیری مقالات 3GPP و آخرین اخبار تلکام.</p>
      </div>
    </div>
  </div>

  <div class="mt-16 rounded-2xl border border-white/5 bg-gradient-to-br from-blue-600/10 to-cyan-600/10 p-8 text-center">
    <h3 class="text-xl font-bold">{t.about.connect}</h3>
    <p class="text-gray-400 mt-2 text-sm">{t.about.connectDesc}</p>
    <div class="flex justify-center gap-4 mt-6">
      <a href="https://github.com/packetalchemy" target="_blank" class="px-6 py-2.5 rounded-xl bg-white/5 border border-white/10 hover:border-blue-500/40 hover:bg-blue-500/10 transition-all text-sm">GitHub Profile</a>
    </div>
  </div>
</section>
</I18nLayout>
