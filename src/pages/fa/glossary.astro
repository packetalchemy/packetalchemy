---
import I18nLayout from '../../layouts/I18nLayout.astro';
import { getLocale } from '../../i18n/index';
const lang = 'fa' as const;
const t = getLocale(lang);
---
<I18nLayout title="واژه‌نامه | PacketAlchemy" lang={lang}>
<section class="relative overflow-hidden">
  <div class="absolute -right-64 -top-64 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>
  <div class="relative max-w-5xl mx-auto px-6 md:px-10 pt-28 pb-12 rtl">
    <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-xs text-blue-300 mb-6">
      <span class="h-1.5 w-1.5 rounded-full bg-blue-400"></span>{t.glossary.badge}
    </div>
    <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight">{t.glossary.title}<span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent"> {t.glossary.titleHighlight}</span></h1>
    <p class="text-gray-400 mt-4 text-lg">{t.glossary.subtitle}</p>
    <div class="mt-8 relative"><svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg><input id="glossary-search" type="text" placeholder={t.glossary.searchPlaceholder} class="w-full md:w-96 pl-12 pr-5 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:border-blue-500/50 focus:outline-none transition text-sm" /></div>
  </div>
</section>
<section class="max-w-5xl mx-auto px-6 md:px-10 pb-20 rtl" id="glossary-list">
  <div class="mb-10"><h2 class="text-sm font-bold text-blue-400 uppercase tracking-widest mb-4">A</h2><div class="space-y-3">
    <div class="term-card rounded-xl border border-white/5 bg-white/[0.02] p-5 hover:border-blue-500/20 transition"><h3 class="font-bold text-white">AMF</h3><p class="text-xs text-blue-400 mt-1">Access and Mobility Management Function</p><p class="text-gray-400 text-sm mt-2">تابع مدیریت دسترسی و تحرک در 5G Core. مسئول ثبت‌نام، اتصال و مدیریت تحرک دستگاه‌ها.</p></div>
    <div class="term-card rounded-xl border border-white/5 bg-white/[0.02] p-5 hover:border-blue-500/20 transition"><h3 class="font-bold text-white">APN</h3><p class="text-xs text-blue-400 mt-1">Access Point Name</p><p class="text-gray-400 text-sm mt-2">نام نقطه دسترسی - دروازه بین شبکه موبایل و شبکه‌های بسته خارجی (اینترنت، IMS).</p></div>
  </div></div>
  <div class="mb-10"><h2 class="text-sm font-bold text-blue-400 uppercase tracking-widest mb-4">G</h2><div class="space-y-3">
    <div class="term-card rounded-xl border border-white/5 bg-white/[0.02] p-5 hover:border-blue-500/20 transition"><h3 class="font-bold text-white">GTP</h3><p class="text-xs text-blue-400 mt-1">GPRS Tunneling Protocol</p><p class="text-gray-400 text-sm mt-2">پروتکل تونلینGPRS - حمل داده کاربر (GTP-U) و سیگنالینگ کنترلی (GTP-C).</p></div>
  </div></div>
  <div class="mb-10"><h2 class="text-sm font-bold text-blue-400 uppercase tracking-widest mb-4">D</h2><div class="space-y-3">
    <div class="term-card rounded-xl border border-white/5 bg-white/[0.02] p-5 hover:border-blue-500/20 transition"><h3 class="font-bold text-white">Diameter</h3><p class="text-xs text-blue-400 mt-1">RFC 6733</p><p class="text-gray-400 text-sm mt-2">پروتکل AAA جایگزین RADIUS. برای احراز هویت (S6a)، کنترل پالیسی (Gx) و شارژ آنلاین (Gy).</p></div>
  </div></div>
  <div class="mb-10"><h2 class="text-sm font-bold text-blue-400 uppercase tracking-widest mb-4">P</h2><div class="space-y-3">
    <div class="term-card rounded-xl border border-white/5 bg-white/[0.02] p-5 hover:border-blue-500/20 transition"><h3 class="font-bold text-white">PFCP</h3><p class="text-xs text-blue-400 mt-1">Packet Forwarding Control Protocol</p><p class="text-gray-400 text-sm mt-2">پروتکل کنترل فورواردینگ - بین SMF و UPF در 5G Core. مدیریت قوانین فورواردینگ و QoS.</p></div>
  </div></div>
  <div class="mb-10"><h2 class="text-sm font-bold text-blue-400 uppercase tracking-widest mb-4">S</h2><div class="space-y-3">
    <div class="term-card rounded-xl border border-white/5 bg-white/[0.02] p-5 hover:border-blue-500/20 transition"><h3 class="font-bold text-white">SBA</h3><p class="text-xs text-blue-400 mt-1">Service-Based Architecture</p><p class="text-gray-400 text-sm mt-2">معماری مبتنی بر سرویس 5G - ارتباط NFها از طریق HTTP/2 REST APIs.</p></div>
  </div></div>
</section>
<script>
  const search = document.getElementById('glossary-search') as HTMLInputElement;
  search?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll('.term-card').forEach((card) => {
      const text = card.textContent?.toLowerCase() || '';
      (card as HTMLElement).style.display = text.includes(val) ? '' : 'none';
    });
  });
</script>
</I18nLayout>
