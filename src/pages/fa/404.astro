---
import I18nLayout from '../../layouts/I18nLayout.astro';
import { getLocale } from '../../i18n/index';
const lang = 'fa' as const;
const t = getLocale(lang);
---
<I18nLayout title="404 - صفحه پیدا نشد | PacketAlchemy" lang={lang}>
<section class="relative overflow-hidden min-h-[70vh] flex items-center">
  <div class="absolute -left-64 top-1/2 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>
  <div class="relative max-w-4xl mx-auto px-6 md:px-10 text-center py-20 rtl">
    <div class="text-[10rem] md:text-[14rem] font-black leading-none bg-gradient-to-br from-blue-500/20 to-cyan-500/10 bg-clip-text text-transparent select-none">404</div>
    <h1 class="text-2xl md:text-3xl font-bold -mt-8">{t['404'].title}</h1>
    <p class="text-gray-400 mt-4 max-w-md mx-auto">{t['404'].desc}</p>
    <div class="flex flex-wrap justify-center gap-3 mt-10">
      <a href="/fa" class="px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 transition-all font-semibold text-sm">{t['404'].home}</a>
      <a href="/fa/blog" class="px-6 py-3 rounded-xl border border-white/10 hover:border-blue-500/40 hover:bg-white/5 transition-all text-sm text-gray-300">{t.nav.blog}</a>
      <a href="/fa/search" class="px-6 py-3 rounded-xl border border-white/10 hover:border-blue-500/40 hover:bg-white/5 transition-all text-sm text-gray-300">{t.nav.search}</a>
    </div>
  </div>
</section>
</I18nLayout>
