---
import I18nLayout from '../../layouts/I18nLayout.astro';
import { getLocale } from '../../i18n/index';
import { getCollection } from 'astro:content';
const lang = 'fa' as const;
const t = getLocale(lang);
const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const postData = posts.map(p => ({ id: p.id, title: p.data.title, description: p.data.description, date: p.data.pubDate.toISOString(), tags: (p.data as any).tags || [] }));
const faTitles: Record<string, string> = { 'gtp-c-signaling-ps-core': 'درک سیگنالینگ GTP-C', 'diameter-signaling-lte-charging': 'سیگنالینگ Diameter در شارژینگ', 'wireshark-filters-ps-core': 'فیلترهای Wireshark', '5g-core-sba-troubleshooting': 'عیب‌یابی SBA 5G Core', 'huawei-ugw-apn-configuration': 'تنظیم APN هوآوی', 'test-post': 'معماری 5G Core', 'gy-interface-deep-dive': 'تحلیل عمیق رابط Gy — راهنمای کامل شارژ آنلاین' };
---
<I18nLayout title="جستجو | PacketAlchemy" lang={lang}>
<section class="relative overflow-hidden">
  <div class="relative max-w-3xl mx-auto px-6 md:px-10 pt-28 pb-12 rtl">
    <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight">{t.search.title}</h1>
    <p class="text-gray-400 mt-4">{t.search.subtitle}</p>
    <div class="mt-8 relative"><svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg><input id="search-input" type="text" placeholder={t.search.placeholder} class="w-full pl-12 pr-5 py-4 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:border-blue-500/50 focus:outline-none transition text-base" /></div>
  </div>
</section>
<section class="max-w-3xl mx-auto px-6 md:px-10 pb-20 rtl">
  <div id="results-count" class="text-sm text-gray-500 mb-6"></div>
  <div id="search-results" class="space-y-4"></div>
  <div id="no-results" class="hidden text-center py-16"><div class="text-5xl mb-4">🔍</div><p class="text-gray-400">{t.search.noResults}</p></div>
</section>
<script define:vars={{ postData }}>
  const posts = postData; const input = document.getElementById('search-input'); const results = document.getElementById('search-results'); const noResults = document.getElementById('no-results'); const count = document.getElementById('results-count');
  const faTitles = { 'gtp-c-signaling-ps-core': 'درک سیگنالینگ GTP-C', 'diameter-signaling-lte-charging': 'سیگنالینگ Diameter', 'wireshark-filters-ps-core': 'فیلترهای Wireshark', '5g-core-sba-troubleshooting': 'عیب‌یابی SBA 5G Core', 'huawei-ugw-apn-configuration': 'تنظیم APN هوآوی', 'test-post': 'معماری 5G Core', 'gy-interface-deep-dive': 'تحلیل عمیق رابط Gy — راهنمای کامل شارژ آنلاین' };
  function renderPost(p) { const tags = p.tags.map(t => '<span class="px-2 py-0.5 text-[10px] border border-white/10 rounded text-gray-500">' + t + '</span>').join(''); return '<a href="/fa/blog/' + p.id + '/" class="block rounded-xl border border-white/5 bg-white/[0.02] p-5 hover:border-blue-500/30 transition-all"><h3 class="text-lg font-bold">' + (faTitles[p.id] || p.title) + '</h3><p class="text-gray-400 text-sm mt-2">' + p.description + '</p><div class="flex gap-1.5 mt-3">' + tags + '</div></a>'; }
  function search(q) { if (!q.trim()) { results.innerHTML = posts.map(renderPost).join(''); count.textContent = posts.length + ' مقاله'; noResults.classList.add('hidden'); return; } const matched = posts.filter(p => p.title.toLowerCase().includes(q.toLowerCase()) || p.description.toLowerCase().includes(q.toLowerCase()) || p.tags.some(t => t.toLowerCase().includes(q.toLowerCase()))); if (!matched.length) { results.innerHTML = ''; noResults.classList.remove('hidden'); count.textContent = ''; } else { noResults.classList.add('hidden'); count.textContent = matched.length + ' نتیجه'; results.innerHTML = matched.map(renderPost).join(''); } }
  results.innerHTML = posts.map(renderPost).join(''); count.textContent = posts.length + ' مقاله';
  input.addEventListener('input', (e) => search(e.target.value));
</script>
</I18nLayout>
