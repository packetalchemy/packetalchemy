---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featured = posts[0];
const rest = posts.slice(1);

function readingTime(body: string): string {
  const words = body.split(/\s+/).length;
  const mins = Math.max(1, Math.ceil(words / 200));
  return `${mins} min read`;
}
---

<MainLayout title="Blog | PacketAlchemy">

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute -right-64 -top-64 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>
    <div class="relative max-w-5xl mx-auto px-6 md:px-10 pt-28 pb-12">
      <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-xs text-blue-300 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse"></span>
        {posts.length} Articles
      </div>
      <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight">
        Technical
        <span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent"> Blog</span>
      </h1>
      <p class="text-gray-400 mt-4 text-lg max-w-2xl">
        Deep dives into telecom protocols, troubleshooting guides, and engineering insights.
      </p>
    </div>
  </section>

  <!-- Featured Post -->
  {featured && (
    <section class="max-w-5xl mx-auto px-6 md:px-10 pb-8">
      <a
        href={`/blog/${featured.id}/`}
        class="block group rounded-2xl border border-white/5 bg-gradient-to-br from-blue-600/10 via-white/[0.02] to-cyan-600/5 p-8 md:p-10 hover:border-blue-500/30 transition-all duration-300"
      >
        <div class="flex items-center gap-3 mb-4">
          <span class="px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-widest bg-blue-500/20 text-blue-300 rounded-md">Featured</span>
          <span class="text-xs text-gray-500 font-mono">
            {featured.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
          <span class="text-xs text-gray-600">· {readingTime(featured.body!)}</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold group-hover:text-blue-400 transition-colors">
          {featured.data.title}
        </h2>
        <p class="text-gray-400 mt-3 max-w-3xl leading-relaxed">
          {featured.data.description}
        </p>
        <div class="flex flex-wrap gap-2 mt-5">
          {(featured.data as any).tags?.map((tag: string) => (
            <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-400 bg-white/[0.02]">{tag}</span>
          ))}
        </div>
        <div class="text-blue-400 text-sm mt-6 font-semibold group-hover:translate-x-1 transition-transform">Read article →</div>
      </a>
    </section>
  )}

  <!-- Posts Grid -->
  <section class="max-w-5xl mx-auto px-6 md:px-10 pb-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {rest.map((post) => (
        <a
          href={`/blog/${post.id}/`}
          class="group rounded-2xl border border-white/5 bg-white/[0.02] p-6 hover:border-blue-500/30 hover:-translate-y-1 transition-all duration-300 flex flex-col"
        >
          <div class="flex items-center gap-2 text-xs text-gray-500 font-mono">
            <span>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            <span>·</span>
            <span>{readingTime(post.body!)}</span>
          </div>
          <h3 class="text-lg font-bold mt-3 group-hover:text-blue-400 transition-colors leading-snug">
            {post.data.title}
          </h3>
          <p class="text-gray-400 text-sm mt-3 leading-relaxed flex-1">
            {post.data.description}
          </p>
          <div class="flex flex-wrap gap-1.5 mt-4">
            {(post.data as any).tags?.slice(0, 3).map((tag: string) => (
              <span class="px-2 py-0.5 text-[10px] border border-white/10 rounded text-gray-500">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="max-w-5xl mx-auto px-6 md:px-10 pb-20">
    <div class="rounded-2xl border border-white/5 bg-gradient-to-br from-blue-600/10 via-transparent to-cyan-600/10 p-8 md:p-12 text-center">
      <div class="text-3xl mb-3">📬</div>
      <h2 class="text-2xl font-bold">Stay Updated</h2>
      <p class="text-gray-400 mt-2 text-sm max-w-md mx-auto">
        Get notified when new articles on telecom engineering, packet analysis, and 5G Core are published.
      </p>
      <form class="mt-6 flex flex-col sm:flex-row gap-3 max-w-md mx-auto" onsubmit="event.preventDefault(); this.querySelector('button').textContent='Subscribed ✓'; this.querySelector('button').disabled=true;">
        <input
          type="email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:border-blue-500/50 focus:outline-none text-sm"
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 transition-all font-semibold text-sm shadow-lg shadow-blue-600/20 whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
      <p class="text-gray-600 text-xs mt-3">No spam. Unsubscribe anytime.</p>
    </div>
  </section>

</MainLayout>
