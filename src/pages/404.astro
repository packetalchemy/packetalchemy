---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 - Page Not Found | PacketAlchemy">

<section class="relative overflow-hidden min-h-[70vh] flex items-center">
  <div class="absolute -left-64 top-1/2 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>

  <div class="relative max-w-4xl mx-auto px-6 md:px-10 text-center py-20">
    <!-- Big 404 -->
    <div class="text-[10rem] md:text-[14rem] font-black leading-none bg-gradient-to-br from-blue-500/20 to-cyan-500/10 bg-clip-text text-transparent select-none">
      404
    </div>

    <h1 class="text-2xl md:text-3xl font-bold -mt-8">Page Not Found</h1>
    <p class="text-gray-400 mt-4 max-w-md mx-auto">
      The page you're looking for doesn't exist or has been moved. Check the URL or explore the links below.
    </p>

    <!-- Quick Links -->
    <div class="flex flex-wrap justify-center gap-3 mt-10">
      <a href="/" class="px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 transition-all font-semibold text-sm">
        Home
      </a>
      <a href="/blog" class="px-6 py-3 rounded-xl border border-white/10 hover:border-blue-500/40 hover:bg-white/5 transition-all text-sm text-gray-300">
        Blog
      </a>
      <a href="/reference" class="px-6 py-3 rounded-xl border border-white/10 hover:border-blue-500/40 hover:bg-white/5 transition-all text-sm text-gray-300">
        Reference
      </a>
      <a href="/about" class="px-6 py-3 rounded-xl border border-white/10 hover:border-blue-500/40 hover:bg-white/5 transition-all text-sm text-gray-300">
        About
      </a>
    </div>
  </div>
</section>

</MainLayout>
