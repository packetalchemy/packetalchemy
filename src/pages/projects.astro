---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Projects | PacketAlchemy">

  <section class="relative overflow-hidden">
    <div class="absolute -left-64 -top-64 w-[500px] h-[500px] rounded-full bg-blue-600/10 blur-[150px]"></div>

    <div class="relative max-w-5xl mx-auto px-6 md:px-10 pt-28 pb-12">
      <div class="inline-flex items-center gap-2 rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-xs text-blue-300 mb-6">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-400"></span>
        Projects & Labs
      </div>

      <h1 class="text-4xl md:text-5xl font-black leading-tight tracking-tight">
        Projects &
        <span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">
          Labs
        </span>
      </h1>

      <p class="text-gray-400 mt-4 text-lg max-w-2xl">
        Real-world telecom simulations and engineering tools — from packet analysis to signaling flows.
      </p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 md:px-10 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Project 1 -->
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-blue-500/30 hover:-translate-y-1 transition-all duration-300">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400">📡</div>
          <h2 class="text-lg font-bold">5G Core Flow Simulator</h2>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Simulated AMF → SMF → UPF signaling flows with GTP analysis.
          UE registration and PDU Session modeling.
        </p>
        <div class="flex gap-2 mt-5">
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">5GC</span>
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">SBA</span>
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">GTP</span>
        </div>
      </div>

      <!-- Project 2 -->
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-blue-500/30 hover:-translate-y-1 transition-all duration-300">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400">🔍</div>
          <h2 class="text-lg font-bold">EPC Troubleshooting Lab</h2>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Packet analysis of MME, SGW, PGW with Wireshark.
          Bearer and S11, S5/S8 signaling troubleshooting.
        </p>
        <div class="flex gap-2 mt-5">
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">EPC</span>
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">GTP</span>
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">Wireshark</span>
        </div>
      </div>

      <!-- Project 3 -->
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-blue-500/30 hover:-translate-y-1 transition-all duration-300">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400">🌐</div>
          <h2 class="text-lg font-bold">PS Core Huawei Lab</h2>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Lab environment for practicing with Huawei equipment: USN, UGW, CG, UPCC.
          APN configuration and session management.
        </p>
        <div class="flex gap-2 mt-5">
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">Huawei</span>
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">PS Core</span>
        </div>
      </div>

      <!-- Project 4 -->
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-7 hover:border-blue-500/30 hover:-translate-y-1 transition-all duration-300">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400">⚡</div>
          <h2 class="text-lg font-bold">Diameter Signaling Analyzer</h2>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Analysis of CCR/CCA flows in LTE charging systems.
          Diameter Gx, Gy, and OCS deep dive.
        </p>
        <div class="flex gap-2 mt-5">
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">Diameter</span>
          <span class="px-2.5 py-0.5 text-[11px] border border-white/10 rounded-md text-gray-500">OCS</span>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
